{
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu24.04",
  "mounts": [
    {
      "source": "${localEnv:HOME}/.codex",
      "target": "/mnt/codex",
      "type": "bind"
    },
    {
      "source": "${localWorkspaceFolderBasename}-node-modules",
      "target": "${containerWorkspaceFolder}/node_modules",
      "type": "volume"
    },
    {
      "source": "${localWorkspaceFolderBasename}-pnpm-store",
      "target": "${containerWorkspaceFolder}/.pnpm-store",
      "type": "volume"
    }
  ],
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/node:2": {
      "version": "22",
      "pnpmVersion": "11.5.0"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:3": {}
  },
  "containerEnv": {
    "CODEX_HOME": "/mnt/codex"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:${containerWorkspaceFolder}/node_modules/.bin",
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  "onCreateCommand": {
    "script": "bash -x .devcontainer/scripts/on-create-command.sh"
  },
  "postCreateCommand": {
    "script": "bash -x .devcontainer/scripts/post-create-command.sh"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "davidanson.vscode-markdownlint",
        "foxundermoon.shell-format@7.2.5",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ]
    }
  }
}
