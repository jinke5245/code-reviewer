{
  "name": "@jinke5245/code-reviewer",
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinke5245/code-reviewer.git"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "codereviewer": "./dist/cli.js"
  },
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    ".schemas",
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "commander": "^15.0.0",
    "handlebars": "^4.7.9",
    "jsonc-parser": "^3.3.1",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "ajv": "^8.20.0",
    "bun": "^1.3.14",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "prepare": "node scripts/prepare-husky.mjs",
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "bundle": "bun build src/cli.ts --target node --packages external --outfile dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "run-s --continue-on-error lint:*",
    "lint-staged": "lint-staged --concurrent false --relative",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2",
    "release": "semantic-release"
  },
  "codereviewer": {
    "review": {
      "maxRounds": 12
    },
    "gitlab": {
      "publish": "inline"
    },
    "prompts": {
      "extraRules": [
        "Write review summaries, findings, and suggestions in Chinese.",
        "Keep comments concise and focused on actionable issues.",
        "When a finding has a safe direct replacement anchored to the selected diff range, populate replacementCode with the complete replacement code so GitLab can render an applyable suggestion block.",
        "Prefer targeted reads over broad file sweeps; stop gathering context once findings are supported."
      ]
    },
    "tools": {
      "limits": {
        "maxToolCalls": 120
      }
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "markdownlint-cli2": {
    "config": {
      "MD012": false,
      "MD034": false,
      "MD036": false,
      "MD041": false
    },
    "globs": [
      "**/*.md"
    ],
    "ignores": [
      "CHANGELOG.md",
      ".agents/**",
      ".cache/**",
      ".pnpm-store/**",
      ".worktrees/**",
      "coverage/**",
      "docs/superpowers/**",
      "dist/**",
      "node_modules/**"
    ]
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": "eslint --fix",
    "*.{json,jsonc,md,yml,yaml}": "prettier --write",
    "**/*.md": "markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2"
  },
  "release": {
    "branches": [
      "main"
    ],
    "tagFormat": "${version}",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": true
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
